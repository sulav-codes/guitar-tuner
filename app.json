{
  "expo": {
    "name": "Guitar Tuner Pro",
    "slug": "guitar-tuner-pro",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.miaoda.appcdi74yoy2sqp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "com.miaoda.appcdi74yoy2sqp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "@siteed/audio-studio",
      {
        "enablePhoneStateHandling": true,
        "enableNotifications": true,
        "enableBackgroundAudio": true,
        "enableDeviceDetection": true,
        "iosBackgroundModes": {
          "useVoIP": false,
          "useAudio": false,
          "useProcessing": false,
          "useLocation": false,
          "useExternalAccessory": false
        },
        "iosConfig": {
          "allowBackgroundAudioControls": false,
          "backgroundProcessingTitle": "Guitar Tuner Pro",
          "microphoneUsageDescription": "Allow Guitar Tuner Pro to access your microphone.",
          "notificationUsageDescription": "Allow Guitar Tuner Pro to send you notifications."
        }
      },
      "@react-native-async-storage/expo-with-async-storage",
      "@react-native-async-storage/expo-with-async-storage"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c8600bc-4bc4-4ae1-8177-09424ef197b9"
      }
    }
  }
}
